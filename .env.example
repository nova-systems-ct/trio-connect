# TRIO Connect — Environment Variables
# Copy to .env.local for local development.
# In Vercel: add under Project → Settings → Environment Variables.

# ─── Supabase (Required for production) ──────────────────────────────────────
# Create a free project at https://supabase.com
# Run supabase/schema.sql in the SQL editor before deploying
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Without Supabase ────────────────────────────────────────────────────────
# The app runs in Demo Mode with 50 students, 5 advisors, and full seed data.
# Demo credentials:
#   Director:  director@trio-demo.edu / TRIODirector2026!
#   Advisor:   advisor@trio-demo.edu  / TRIOAdvisor2026!
#   Student:   student@trio-demo.edu  / TRIOStudent2026!
